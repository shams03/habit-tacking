# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:password@localhost:5432/goal_tracker"

# Groq API key — get from https://console.groq.com
GROQ_API_KEY="gsk_..."

# App base URL (used for CORS / callback URLs)
NEXTAUTH_URL="http://localhost:3000"

# LLM cost guard — max tokens allowed per month before blocking
LLM_MONTHLY_TOKEN_BUDGET=1000000
